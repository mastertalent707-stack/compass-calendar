{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx biome check --write --assist-enabled=true --changed --since=main --no-errors-on-unmatched >/dev/null",
            "timeout": 60,
            "statusMessage": "Applying Biome fixes to branch changes"
          }
        ]
      }
    ]
  }
}
